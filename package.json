{
  "name": "gestor-blockchain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest test/unit --passWithNoTests",
    "test:integration": "jest test/integration --passWithNoTests",
    "test:contract": "jest test/contract --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check": "run-s lint typecheck test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "typeorm": "ts-node --project tsconfig.typeorm.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- -d src/shared/db/data-source.ts migration:generate migrations/auto",
    "migration:run": "npm run typeorm -- -d src/shared/db/data-source.ts migration:run",
    "migration:revert": "npm run typeorm -- -d src/shared/db/data-source.ts migration:revert"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/express": "^5.0.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "fabric": "^7.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.2.2",
    "shadcn": "^4.0.8",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jest": "^30.3.0",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
